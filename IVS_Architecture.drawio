<mxfile host="app.diagrams.net">
  <diagram name="IVS Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1"
      connect="1" arrows="1" fold="1" page="1" pageScale="1"
      pageWidth="1200" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Layer E -->
        <mxCell id="E" value="Layer E: Web Dashboard (Read-Only Visualization)
• Live Map
• Route Polyline
• Event Timeline
• Risk Status
• Emergency Indicator
• Post-Trip Report"
          style="rounded=1;whiteSpace=wrap;fillColor=#E3F2FD;strokeColor=#1E88E5;fontSize=12"
          vertex="1" parent="1">
          <mxGeometry x="150" y="20" width="900" height="140" as="geometry"/>
        </mxCell>

        <!-- Layer D -->
        <mxCell id="D" value="Layer D: Backend & Storage (Flask + MongoDB)
• REST APIs
• Trip Lifecycle
• GPS Storage
• Events & Risk History
• SOS Logging"
          style="rounded=1;whiteSpace=wrap;fillColor=#E8F5E9;strokeColor=#43A047;fontSize=12"
          vertex="1" parent="1">
          <mxGeometry x="150" y="200" width="900" height="160" as="geometry"/>
        </mxCell>

        <!-- Layer C -->
        <mxCell id="C" value="Layer C: AI Decision & Risk Engine
• Multi-signal Risk Scoring
• Temporal Reasoning
• Risk Levels (Low → Critical)
• Driver Alerts
• Emergency Escalation
“ML detects patterns, AI decides meaning”"
          style="rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;strokeColor=#FB8C00;fontSize=12"
          vertex="1" parent="1">
          <mxGeometry x="150" y="400" width="900" height="180" as="geometry"/>
        </mxCell>

        <!-- Layer B -->
        <mxCell id="B" value="Layer B: ML Monitoring (Perception Only)
Driver:
• Drowsiness (PERCLOS, yawning)
• Distraction (head pose, gaze)

Passenger:
• Distress (support)
• SOS Gesture (X-shape 3–5s)

Outputs:
• ML signals (confidence, duration)
• SOS event (ML_GESTURE)"
          style="rounded=1;whiteSpace=wrap;fillColor=#FCE4EC;strokeColor=#D81B60;fontSize=12"
          vertex="1" parent="1">
          <mxGeometry x="150" y="620" width="900" height="200" as="geometry"/>
        </mxCell>

        <!-- Layer A -->
        <mxCell id="A" value="Layer A: Mobile App (Android – IoT Device)
• Start / End Trip
• Foreground GPS Tracking
• Manual SOS Button

Sends:
• GPS → Backend
• SOS → Backend

(No ML, No Risk Computation)"
          style="rounded=1;whiteSpace=wrap;fillColor=#E1F5FE;strokeColor=#0288D1;fontSize=12"
          vertex="1" parent="1">
          <mxGeometry x="150" y="860" width="900" height="160" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="e1" style="endArrow=block;strokeWidth=2" edge="1" parent="1"
          source="A" target="D">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" style="endArrow=block;strokeWidth=2" edge="1" parent="1"
          source="B" target="C">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="endArrow=block;strokeWidth=2" edge="1" parent="1"
          source="C" target="D">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" style="endArrow=block;strokeWidth=2" edge="1" parent="1"
          source="D" target="E">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SOS Dual Path -->
        <mxCell id="e5" value="SOS (ML Gesture)"
          style="endArrow=block;strokeColor=#D32F2F;strokeWidth=3"
          edge="1" parent="1" source="B" target="D">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" value="SOS (Mobile App)"
          style="endArrow=block;strokeColor=#D32F2F;strokeWidth=3"
          edge="1" parent="1" source="A" target="D">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
